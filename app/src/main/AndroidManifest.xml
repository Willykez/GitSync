<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Needed for clone / fetch / push / pull over the network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Repos now live in a PUBLIC folder (/storage/emulated/0/.RepoMaster/repos)
        instead of this app's private Android/data folder, so any file
        manager, other app, or PC-over-USB can reach the files. See
        data/PublicStorage.kt for the full reasoning.

        On Android 11+ (API 30+), reading/writing arbitrary public folders
        needs the "All files access" special permission — granted manually
        in system Settings, not a normal runtime popup.
        On Android 10 and below, the classic WRITE_EXTERNAL_STORAGE runtime
        permission is enough.
    -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!--
        Lets the system installer treat an APK handed to it by this app (via
        FileProvider, from the Actions screen's "Build outputs" → Install
        button) as a normal install source, instead of blocking it as an
        "unknown app" the way a plain file manager tap would be. Required on
        Android 8+ (API 26+); the system still shows its own confirmation
        dialog before anything installs, this just lets that dialog appear
        in the first place.
    -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!--
        Android 13+ (API 33+) requires this runtime permission before any
        notification can be shown — including the background sync summary
        notification (see sync/SyncNotifier.kt). Requested from
        SettingsScreen when the person turns background sync on, since
        SyncWorker itself runs headless with no Activity to prompt from.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".App"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RepoMaster"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.RepoMaster">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Scoped only to ".RepoMaster/apk-downloads/" (see
            res/xml/file_paths.xml and data/PublicStorage.apkDownloadsDir /
            data/ApkInstaller.kt) — not all of shared storage — so a
            content:// grant handed to the system installer can't be used
            to reach anything else on the device.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
