<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Matches PublicStorage.apkDownloadsDir() — .RepoMaster/apk-downloads/<repoName>/
         under shared storage root. This is the only public location the FileProvider
         grants access into, not all of shared storage. -->
    <external-path name="apk_downloads" path=".RepoMaster/apk-downloads/" />
</paths>
